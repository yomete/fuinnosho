    {
      "id": "6d16486b-8f28-4106-a23a-33978b89fb75",
      "name": "Cosmo 500T",
      "brand": "FILMRISS",
      "iso": 500,
      "format": "35mm",
      "type": "Color Negative",
      "expiration_date": "2027-01-01",
